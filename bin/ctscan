#!/usr/bin/env bash
# ctscan — macOS system health scanner
# https://github.com/onurtellioglu/ctscan

set -uo pipefail

VERSION="0.3.8"

# ──────────────────────────────────────────────
# Color helpers
# ──────────────────────────────────────────────
USE_COLOR=true
QUIET=false
FORMAT="text"

# ── JSON result collection ──────────────────────
declare -A _JSON_STATUS=()
declare -A _JSON_VALUE=()
declare -A _JSON_MSG=()

json_result() {
  # Usage: json_result <module> <status> <value> <message>
  # status: ok | warn | error | unavailable
  local mod="$1" status="$2" value="$3" message="${4:-}"
  # Proper JSON escaping: backslash first, then double-quote, then control chars
  value="${value//\\/\\\\}"; value="${value//\"/\\\"}"; value="${value//$'\n'/\\n}"; value="${value//$'\t'/\\t}"
  message="${message//\\/\\\\}"; message="${message//\"/\\\"}"; message="${message//$'\n'/\\n}"; message="${message//$'\t'/\\t}"
  _JSON_STATUS["$mod"]="$status"
  _JSON_VALUE["$mod"]="$value"
  _JSON_MSG["$mod"]="$message"
}

emit_json() {
  local first=true
  printf '{\n'
  for mod in "${ALL_MODULES[@]}"; do
    [[ -z "${_JSON_STATUS[$mod]+x}" ]] && continue
    $first || printf ',\n'
    printf '  "%s": {"status": "%s", "value": "%s", "message": "%s"}' \
      "$mod" "${_JSON_STATUS[$mod]}" "${_JSON_VALUE[$mod]}" "${_JSON_MSG[$mod]}"
    first=false
  done
  printf '\n}\n'
}

# In JSON mode suppress all human-readable output
_maybe_silence_printing() {
  if [[ "$FORMAT" == "json" ]]; then
    print_header() { :; }
    print_ok()     { :; }
    print_warn()   { :; }
    print_info()   { :; }
    print_error()  { :; }
    color()        { :; }
  fi
}

color() {
  local code="$1"; shift
  if $USE_COLOR; then
    printf '\033[%sm%s\033[0m\n' "$code" "$*"
  else
    printf '%s\n' "$*"
  fi
}

print_header() { color "1;34" "══ $* ══"; }
print_ok()     { color "0;32" "  ✓ $*"; }
print_warn()   { color "0;33" "  ⚠ $*"; }
print_info()   { color "0;37" "  · $*"; }
print_error()  { color "0;31" "ERROR: $*" >&2; }

# ──────────────────────────────────────────────
# Module: identity
# ──────────────────────────────────────────────
check_identity() {
  print_header "Identity"
  local hostname model os_ver
  hostname=$(scutil --get ComputerName 2>/dev/null || hostname)
  if [[ -n "${_SP_HARDWARE:-}" ]]; then
    model=$(echo "$_SP_HARDWARE" | awk -F': ' '/Model Name/{print $2; exit}')
  else
    model=$(system_profiler SPHardwareDataType 2>/dev/null | awk -F': ' '/Model Name/{print $2; exit}')
  fi
  os_ver=$(sw_vers -productVersion 2>/dev/null)

  local uptime_raw uptime_dur
  uptime_raw=$(uptime)
  uptime_dur=$(echo "$uptime_raw" | awk -F'up ' '{print $2}' | awk -F',' '{print $1}' | xargs)

  json_result "identity" "ok" "macOS ${os_ver}" "${hostname}${model:+, $model}, up ${uptime_dur}"

  $QUIET && return

  print_info "Host:    $hostname"
  [[ -n "$model" ]] && print_info "Model:   $model"
  print_info "macOS:   $os_ver"

  local load_avg
  load_avg=$(echo "$uptime_raw" | awk -F'load averages:' '{print $2}' | xargs)
  print_info "Uptime:  $uptime_dur"
  [[ -n "$load_avg" ]] && print_info "Load:    $load_avg"

  local who_out user_count
  who_out=$(who 2>/dev/null)
  user_count=$(echo "$who_out" | grep -c .)
  if [[ "$user_count" -gt 0 ]]; then
    print_info "Users:   $user_count session(s)"
    echo "$who_out" | while IFS= read -r line; do print_info "  $line"; done
  fi
}

# ──────────────────────────────────────────────
# Module: brew
# ──────────────────────────────────────────────
check_brew() {
  print_header "Homebrew"
  if ! command -v brew &>/dev/null; then
    print_warn "Homebrew not installed"
    json_result "brew" "unavailable" "" "Homebrew not installed"
    return
  fi

  local outdated
  outdated=$(brew outdated 2>/dev/null | wc -l | tr -d ' ')
  local formulae_count casks_count
  formulae_count=$(brew list --formula 2>/dev/null | wc -l | tr -d ' ')
  casks_count=$(brew list --cask 2>/dev/null | wc -l | tr -d ' ')
  local pkg_summary="${formulae_count} formulae, ${casks_count} casks"

  if [[ "$outdated" -gt 0 ]]; then
    print_warn "$outdated package(s) outdated — run: brew upgrade"
    json_result "brew" "warn" "${outdated} outdated" "$pkg_summary"
  else
    json_result "brew" "ok" "up to date" "$pkg_summary"
  fi

  $QUIET && return

  local leaves casks
  leaves=$(mktemp "${TMPDIR:-/tmp}/ctscan_leaves.XXXXXX")
  casks=$(mktemp "${TMPDIR:-/tmp}/ctscan_casks.XXXXXX")
  brew leaves 2>/dev/null > "$leaves" &
  brew list --cask 2>/dev/null > "$casks" &
  wait
  echo
  color "0;32" "  Formulae (leaves):"
  xargs -n 5 < "$leaves" | while IFS= read -r line; do print_info "$line"; done
  echo
  color "0;32" "  Casks:"
  xargs -n 5 < "$casks" | while IFS= read -r line; do print_info "$line"; done
  rm -f "$leaves" "$casks"

  if [[ "$outdated" -eq 0 ]]; then
    print_ok "All packages up to date"
  fi
}

# ──────────────────────────────────────────────
# Module: agents
# ──────────────────────────────────────────────
check_agents() {
  print_header "Launch Agents & Daemons"

  json_result "agents" "ok" "" ""

  $QUIET && return

  local dirs=(
    "$HOME/Library/LaunchAgents"
    "/Library/LaunchAgents"
    "/Library/LaunchDaemons"
  )
  for dir in "${dirs[@]}"; do
    color "0;32" "  $dir:"
    local files
    files=$(ls "$dir" 2>/dev/null)
    if [[ -n "$files" ]]; then
      echo "$files" | while IFS= read -r f; do print_info "$f"; done
    else
      print_info "(empty)"
    fi
  done
}

# ──────────────────────────────────────────────
# Module: storage
# ──────────────────────────────────────────────
check_storage() {
  print_header "Storage"

  local cache_size_kb cache_size_gb
  # On APFS the 'Used' column in df only counts the mounted volume (e.g. System).
  # Actual used space = Total − Available, which correctly accounts for all volumes.
  local total_k avail_k used_k _rest
  read -r _rest total_k _rest avail_k _rest < <(df -k / 2>/dev/null | tail -1)
  used_k=$(( total_k - avail_k ))
  local pct=$(( used_k * 100 / total_k ))

  _fmt_kb() {
    awk -v k="$1" 'BEGIN{
      if(k>=1073741824) printf "%.1fT",k/1073741824
      else if(k>=1048576) printf "%.1fG",k/1048576
      else printf "%.0fM",k/1024
    }'
  }
  local used total
  used=$(_fmt_kb "$used_k")
  total=$(_fmt_kb "$total_k")

  # Disk summary line (always shown)
  print_info "Disk: $used used / $total total (${pct}% full)"

  # Cache threshold check (quiet mode warning)
  if [[ -d ~/Library/Caches ]]; then
    cache_size_kb=$(du -sk ~/Library/Caches 2>/dev/null | awk '{print $1}')
    if [[ "$cache_size_kb" -gt 5242880 ]]; then
      cache_size_gb=$(awk -v k="$cache_size_kb" 'BEGIN{printf "%.1f", k/1048576}')
      print_warn "Cache total: ${cache_size_gb}GB (>5GB) — consider clearing ~/Library/Caches"
      json_result "storage" "warn" "$used / $total" "${pct}% used · ${cache_size_gb}GB cache"
    else
      json_result "storage" "ok" "$used / $total" "${pct}% used"
    fi
  fi

  $QUIET && return

  # Raw du output — cache and AppSupport merged, no sub-headers
  du -sh ~/Library/Caches/* 2>/dev/null | sort -rh | head -5 | while IFS= read -r line; do print_info "$line"; done
  du -sh ~/Library/Application\ Support/* 2>/dev/null | sort -rh | head -5 | while IFS= read -r line; do print_info "$line"; done
}

# ──────────────────────────────────────────────
# Module: ssd
# ──────────────────────────────────────────────
check_ssd() {
  print_header "SSD Wear"
  if ! command -v smartctl &>/dev/null; then
    print_warn "smartmontools not installed — install with: brew install smartmontools"
    json_result "ssd" "unavailable" "" "smartmontools not installed"
    return
  fi

  local smart_out pct_used
  # smartctl uses bitmask exit codes — non-zero doesn't mean failure
  smart_out=$(smartctl -a /dev/disk0 2>/dev/null)
  if [[ -z "$smart_out" ]]; then
    print_warn "smartctl could not read disk0 (unsupported disk)"
    json_result "ssd" "unavailable" "" "smartctl could not read disk0"
    return
  fi

  pct_used=$(echo "$smart_out" | grep -i "Percentage Used" | awk '{print $NF}' | tr -d '%')
  local tbw
  tbw=$(echo "$smart_out" | grep -i "Data Units Written" | awk -F'[[]' '{print $2}' | tr -d ']')

  if [[ -z "$pct_used" ]]; then
    $QUIET || print_info "SSD wear data not available"
    json_result "ssd" "unavailable" "" "wear data not available"
    return
  fi

  if [[ "$pct_used" -gt 80 ]]; then
    print_warn "SSD wear: ${pct_used}% used (>80%) — consider planning replacement"
    json_result "ssd" "warn" "${pct_used}% used" "consider replacement"
  else
    json_result "ssd" "ok" "${pct_used}% used" "${tbw:+$tbw written}"
  fi

  $QUIET && return

  # Raw smartctl lines verbatim
  echo "$smart_out" | grep -E "Percentage Used|Data Units Written" | while IFS= read -r line; do
    print_info "$line"
  done
}

# ──────────────────────────────────────────────
# Module: battery
# ──────────────────────────────────────────────
check_battery() {
  print_header "Battery"

  local cycles health_pct max_cap

  local ioreg_out
  ioreg_out=$(ioreg -r -c AppleSmartBattery 2>/dev/null)

  cycles=$(echo "$ioreg_out" | grep -E '^\s+"CycleCount"' | awk '{print $NF}')
  local design_cap fcc_cap
  # DesignCapacity and FccComp1 live inside the nested BatteryData dict — match anywhere
  design_cap=$(echo "$ioreg_out" | grep -o '"DesignCapacity"=[0-9]*' | cut -d= -f2 | head -1)
  fcc_cap=$(echo "$ioreg_out"    | grep -o '"FccComp1"=[0-9]*'      | cut -d= -f2 | head -1)

  # Precise health: FccComp1 / DesignCapacity
  local health_pct=""
  if [[ -n "$fcc_cap" && -n "$design_cap" && "$design_cap" -gt 0 ]]; then
    health_pct=$(awk -v f="$fcc_cap" -v d="$design_cap" 'BEGIN{printf "%.1f", f/d*100}')
  fi

  local _bat_status="ok"
  local _bat_msg=""
  if [[ -n "$health_pct" ]]; then
    local health_int=${health_pct%.*}
    if [[ "${health_int:-100}" -lt 80 ]]; then
      print_warn "Battery health: ${health_pct}% (<80%) — service recommended"
      _bat_status="warn"
      _bat_msg="health below 80%"
    fi
  fi
  if [[ -n "$cycles" && "$cycles" -gt 1000 ]]; then
    print_warn "Cycle count: $cycles (>1000)"
    _bat_status="warn"
    _bat_msg="${_bat_msg:+$_bat_msg, }cycles >1000"
  fi
  json_result "battery" "$_bat_status" "${health_pct:----}%" "${_bat_msg:-$cycles cycles}"

  $QUIET && return

  local batt_line charge_pct charge_state time_remain
  batt_line=$(pmset -g batt 2>/dev/null | grep -v "Now drawing" | grep '%')
  charge_pct=$(echo "$batt_line" | grep -oE '[0-9]+%' | head -1)
  charge_state=$(echo "$batt_line" | awk -F';' '{gsub(/^[[:space:]]+/,"",$2); print $2}' | xargs)
  time_remain=$(echo "$batt_line" | awk -F';' '{match($3,/[0-9]+:[0-9]+/); print substr($3,RSTART,RLENGTH)}' | xargs)
  [[ "$time_remain" == "0:00" ]] && time_remain=""
  [[ -n "$charge_pct" ]]   && print_info "Charge:  ${charge_pct} (${charge_state}${time_remain:+, $time_remain})"
  [[ -n "$design_cap" && -n "$fcc_cap" ]] && \
    print_info "Health:  ${health_pct:----}% | ${fcc_cap} mAh real / ${design_cap} mAh design | ${cycles} cycles"
}

# ──────────────────────────────────────────────
# Module: thermal
# ──────────────────────────────────────────────
check_thermal() {
  print_header "Thermal & GPU"

  local therm_out pressure
  therm_out=$(pmset -g therm 2>/dev/null)
  pressure=$(echo "$therm_out" | grep -i "Thermal Level" | awk '{print $NF}')

  local cpu_limit
  cpu_limit=$(echo "$therm_out" | grep -oE 'CPU_Speed_Limit = [0-9]+' | awk '{print $NF}')

  if [[ -n "$cpu_limit" && "$cpu_limit" -lt 100 ]]; then
    print_warn "CPU throttled: speed limit at ${cpu_limit}%"
    json_result "thermal" "warn" "${cpu_limit}% speed limit" "CPU throttled"
  elif [[ -n "$pressure" && "$pressure" != "0" && "$pressure" != "Nominal" ]]; then
    print_warn "Thermal pressure: $pressure (not Nominal)"
    json_result "thermal" "warn" "$pressure" "thermal pressure elevated"
  else
    $QUIET || print_ok "No thermal throttling detected"
    json_result "thermal" "ok" "Normal" ""
  fi

  $QUIET && return

  # Speed limits (filter noisy "Note:" lines)
  echo "$therm_out" | grep -v '^$' | grep -v '^Note:' | while IFS= read -r line; do print_info "$line"; done

  print_info "GPU Activity Check:"
  if [[ -n "${_SP_DISPLAYS:-}" ]]; then
    echo "$_SP_DISPLAYS" | grep -i "Vendor" | while IFS= read -r line; do print_info "$line"; done
  else
    system_profiler SPDisplaysDataType 2>/dev/null | grep -i "Vendor" | while IFS= read -r line; do print_info "$line"; done
  fi
}

# ──────────────────────────────────────────────
# Module: memory
# ──────────────────────────────────────────────
check_memory() {
  print_header "Memory"

  local swap_out swap_used_gb swap_used_mb
  swap_out=$(sysctl vm.swapusage 2>/dev/null)
  # Example: vm.swapusage: total = 2048.00M  used = 512.00M  free = 1536.00M
  swap_used_mb=$(sysctl vm.swapusage 2>/dev/null | awk -F'used = ' '{split($2,a," "); gsub(/M/,"",a[1]); print a[1]}')
  swap_used_gb=$(awk -v m="${swap_used_mb:-0}" 'BEGIN{printf "%.2f", m/1024}')

  local swap_mb_int=${swap_used_mb%.*}
  local swap_mb_threshold=2048  # 2GB

  local ram_gb
  ram_gb=$(sysctl -n hw.memsize 2>/dev/null | awk '{printf "%.0f", $1/1073741824}')

  if [[ -n "$swap_used_mb" && "${swap_mb_int:-0}" -gt "$swap_mb_threshold" ]]; then
    print_warn "Swap usage: ${swap_used_gb}GB (>2GB) — memory pressure high"
    json_result "memory" "warn" "${swap_used_gb}GB swap" "${ram_gb:+${ram_gb}GB RAM}"
  else
    json_result "memory" "ok" "${swap_used_gb:-0}GB swap" "${ram_gb:+${ram_gb}GB RAM}"
  fi

  $QUIET && return

  memory_pressure 2>/dev/null | tail -3 | while IFS= read -r line; do
    [[ -n "$line" ]] && print_info "$line"
  done

  local swap_total swap_used_disp swap_free encrypted_tag
  swap_total=$(echo "$swap_out"     | awk -F'total = ' '{split($2,a," "); print a[1]}')
  swap_used_disp=$(echo "$swap_out" | awk -F'used = '  '{split($2,a," "); print a[1]}')
  swap_free=$(echo "$swap_out"      | awk -F'free = '  '{split($2,a," "); print a[1]}')
  [[ "$swap_out" == *"encrypted"* ]] && encrypted_tag=" (encrypted)"
  print_info "Swap:    ${swap_used_disp:-?} used / ${swap_total:-?} total${encrypted_tag:-}"
}

# ──────────────────────────────────────────────
# Module: processes
# ──────────────────────────────────────────────
check_processes() {
  print_header "Processes"

  local ps_out
  ps_out=$(ps aux 2>/dev/null)

  # Quiet threshold: any single process >80% CPU
  local high_cpu_proc high_cpu_pct_full high_cpu_path high_cpu_pct
  high_cpu_proc=$(echo "$ps_out" | awk 'NR>1 {print $3, $11}' | sort -rn | head -1)
  read -r high_cpu_pct_full high_cpu_path <<< "$high_cpu_proc"
  high_cpu_pct=${high_cpu_pct_full%.*}
  if [[ -n "$high_cpu_pct" && "$high_cpu_pct" -gt 80 ]]; then
    local proc_name=${high_cpu_path##*/}
    print_warn "High CPU: $proc_name at ${high_cpu_pct_full}%"
    json_result "processes" "warn" "${high_cpu_pct_full}% CPU" "$proc_name"
  else
    json_result "processes" "ok" "" ""
  fi

  $QUIET && return

  echo
  color "0;32" "  Top by CPU:"
  echo "$ps_out" | awk 'NR>1 {
    n=split($11,a,"/"); printf "%5.1f%%  %s\n", $3, a[n]
  }' | sort -rn | head -5 | while IFS= read -r line; do print_info "$line"; done

  echo
  color "0;32" "  Top by Memory:"
  echo "$ps_out" | awk 'NR>1 {
    n=split($11,a,"/"); printf "%10d %s\n", $6, a[n]
  }' | sort -rn | head -5 | awk '{
    kb=$1; name=$2
    if (kb>=1048576) printf "%-6s  %s\n", sprintf("%.1fG",kb/1048576), name
    else if (kb>=1024) printf "%-6s  %s\n", int(kb/1024)"M", name
    else printf "%-6s  %s\n", kb"K", name
  }' | while IFS= read -r line; do print_info "$line"; done
}

# ──────────────────────────────────────────────
# Module: docker
# ──────────────────────────────────────────────
check_docker() {
  print_header "Docker"

  if ! command -v docker &>/dev/null; then
    print_info "Docker not installed — install from https://www.docker.com"
    json_result "docker" "unavailable" "" "Docker not installed"
    return
  fi

  local ps_out
  if ! ps_out=$(docker ps 2>&1); then
    print_info "Docker not running"
    json_result "docker" "unavailable" "" "Docker not running"
    return
  fi

  local running
  running=$(echo "$ps_out" | tail -n +2 | wc -l | tr -d ' ')

  if [[ "$running" -eq 0 ]]; then
    print_ok "No containers running"
    json_result "docker" "ok" "0 containers" ""
  else
    json_result "docker" "ok" "$running containers" ""
    print_info "Running containers: $running"
    echo "$ps_out" | tail -n +2 | while IFS= read -r line; do
      local image status
      image=$(echo "$line" | awk '{print $2}')
      status=$(echo "$line" | awk '{for(i=5;i<=NF;i++) printf "%s ", $i; print ""}' | sed 's/ $//')
      print_info "$(printf '%-22s %s' "$image" "$status")"
    done
  fi

  $QUIET && return

  local df_out
  df_out=$(docker system df 2>/dev/null)
  if [[ -n "$df_out" ]]; then
    echo
    local images vols img_size cont_size vol_size total_size
    read -r images img_size vols vol_size cont_size total_size < <(echo "$df_out" | awk '
      /^Images/       { im=$2; ims=$4 }
      /^Containers/   { cs=$4 }
      /^Local Volumes/{ vo=$2; vos=$4 }
      /^Build Cache/  { bc=$4 }
      END { print im, ims, vo, vos, cs, bc }
    ')
    print_info "Images: ${images:-0}  |  Volumes: ${vols:-0}"
    print_info "Disk usage: ${img_size:-0} images · ${cont_size:-0} containers · ${vol_size:-0} volumes"
  fi
}

# ──────────────────────────────────────────────
# Module: timemachine
# ──────────────────────────────────────────────
check_timemachine() {
  print_header "Time Machine"

  local latest_backup dest_info status_out
  latest_backup=$(tmutil latestbackup 2>/dev/null)
  dest_info=$(tmutil destinationinfo 2>/dev/null)

  if [[ -z "$latest_backup" && -z "$dest_info" ]]; then
    print_info "Time Machine not configured"
    json_result "timemachine" "unavailable" "" "not configured"
    return
  fi

  # Parse last backup date from path (format: .../YYYY-MM-DD-HHMMSS)
  local backup_date backup_ts now_ts age_hours age_display
  backup_date=$(echo "$latest_backup" | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{6}' | tail -1)

  if [[ -n "$backup_date" ]]; then
    local date_part time_part
    date_part=$(echo "$backup_date" | cut -c1-10)
    time_part=$(echo "$backup_date" | cut -c12-17)
    local formatted_time="${time_part:0:2}:${time_part:2:2}"
    backup_ts=$(date -j -f "%Y-%m-%d %H%M%S" "${date_part} ${time_part}" "+%s" 2>/dev/null)
    now_ts=$(date "+%s")
    if [[ -n "$backup_ts" ]]; then
      age_hours=$(( (now_ts - backup_ts) / 3600 ))
      if [[ "$age_hours" -ge 24 ]]; then
        local age_days=$(( age_hours / 24 ))
        local _ds; [[ $age_days -eq 1 ]] && _ds="" || _ds="s"
        age_display="${age_days} day${_ds} ago"
        print_warn "Last backup: $age_display — Time Machine may not be running"
        json_result "timemachine" "warn" "$age_display" "backup overdue"
      else
        local _hs; [[ $age_hours -eq 1 ]] && _hs="" || _hs="s"
        age_display="${age_hours} hour${_hs} ago"
        print_ok "Last backup: $age_display ($date_part $formatted_time)"
        json_result "timemachine" "ok" "$age_display" ""
      fi
    fi
  else
    print_info "Last backup: unknown"
    json_result "timemachine" "ok" "unknown" ""
  fi

  $QUIET && return

  # Destination name
  local dest_name
  dest_name=$(echo "$dest_info" | awk -F': ' '/Name/{print $2; exit}')
  local dest_kind
  dest_kind=$(echo "$dest_info" | awk -F': ' '/Kind/{print $2; exit}')
  [[ -n "$dest_name" ]] && print_info "Destination: $dest_name${dest_kind:+ ($dest_kind)}"

  # Status
  local status_out bkp_status bkp_progress
  status_out=$(tmutil status 2>/dev/null)
  if echo "$status_out" | grep -q '"Running" = 1'; then
    bkp_progress=$(echo "$status_out" | grep -i "Percent" | grep -oE '[0-9.]+' | head -1)
    if [[ -n "$bkp_progress" ]]; then
      local pct_int
      pct_int=$(awk -v p="$bkp_progress" 'BEGIN{printf "%d", p*100}')
      print_info "Status: backing up (${pct_int}% complete)"
    else
      print_info "Status: backing up"
    fi
  else
    print_info "Status: idle"
  fi
}

# ──────────────────────────────────────────────
# Module: updates
# ──────────────────────────────────────────────
check_updates() {
  print_header "Updates"

  local su_out
  su_out=$(softwareupdate -l 2>&1)

  # Filter out noise lines
  local updates
  updates=$(echo "$su_out" | grep -E '^\s*\*' | sed 's/^\s*\* //')

  local count
  count=$(echo "$updates" | grep -c '[^[:space:]]' 2>/dev/null || true)

  local os_ver
  os_ver=$(sw_vers -productVersion 2>/dev/null)

  if [[ "$count" -gt 0 ]]; then
    print_warn "$count update$( [[ $count -eq 1 ]] || echo s ) available"
    json_result "updates" "warn" "$count available" "macOS ${os_ver}"
    $QUIET && return
    echo "$updates" | while IFS= read -r line; do
      [[ -n "$line" ]] && print_info "$line"
    done
  else
    print_ok "No updates available"
    json_result "updates" "ok" "up to date" "macOS ${os_ver}"
  fi
}

# ──────────────────────────────────────────────
# Module: wifi
# ──────────────────────────────────────────────
check_wifi() {
  print_header "Wi-Fi"

  local wifi_out signal_line signal_dbm
  if [[ -n "${_SP_AIRPORT:-}" ]]; then
    wifi_out="$_SP_AIRPORT"
  else
    wifi_out=$(system_profiler SPAirPortDataType 2>/dev/null)
  fi

  signal_line=$(echo "$wifi_out" | grep -i "Signal / Noise" | head -1)
  signal_dbm=$(echo "$signal_line" | grep -oE -- '-[0-9]+ dBm' | head -1 | grep -oE -- '-[0-9]+')

  local ssid
  ssid=$(echo "$wifi_out" | awk '/Current Network Information:/{getline; gsub(/^[[:space:]]+|:[[:space:]]*$/,"",$0); if (length($0)>0) {print; exit}}')

  if [[ -n "$signal_dbm" && "$signal_dbm" -lt -70 ]]; then
    print_warn "Wi-Fi signal weak: ${signal_dbm} dBm (<-70 dBm)"
    json_result "wifi" "warn" "${signal_dbm} dBm" "${ssid:-signal weak}"
  else
    json_result "wifi" "ok" "${signal_dbm:----} dBm" "${ssid:-}"
  fi

  $QUIET && return

  local noise_dbm txrate
  ssid=$(echo "$wifi_out" | awk '/Current Network Information:/{getline; gsub(/^[[:space:]]+|:[[:space:]]*$/,"",$0); if (length($0)>0) {print; exit}}')
  noise_dbm=$(echo "$wifi_out" | grep -i "Signal / Noise" | head -1 | grep -oE '\-[0-9]+ dBm' | tail -1 | grep -oE '\-[0-9]+')
  txrate=$(echo "$wifi_out" | grep -i "Transmit Rate" | head -1 | awk -F': ' '{print $2}' | xargs)

  [[ -n "$ssid" ]]       && print_info "SSID:    $ssid"
  [[ -n "$signal_dbm" ]] && print_info "Signal:  ${signal_dbm} dBm / Noise: ${noise_dbm} dBm"
  [[ -n "$txrate" ]]     && print_info "TX Rate: ${txrate} Mbps"
}

# ──────────────────────────────────────────────
# Module: security
# ──────────────────────────────────────────────
check_security() {
  print_header "Security"

  local fv_status sip_status
  fv_status=$(fdesetup status 2>/dev/null)
  sip_status=$(csrutil status 2>/dev/null)

  # Threshold checks for --quiet
  local _sec_status="ok" _sec_msg=""
  shopt -s nocasematch
  if [[ "$fv_status" == *"filevault is off"* ]]; then
    print_warn "FileVault: OFF — disk is not encrypted"
    _sec_status="warn"
    _sec_msg="FileVault off"
  fi
  if [[ "$sip_status" == *"disabled"* ]]; then
    print_warn "SIP: DISABLED"
    _sec_status="warn"
    _sec_msg="${_sec_msg:+$_sec_msg, }SIP disabled"
  fi
  shopt -u nocasematch
  local _sec_val; [[ "$_sec_status" == "ok" ]] && _sec_val="protected" || _sec_val="issues found"
  json_result "security" "$_sec_status" "$_sec_val" "${_sec_msg:-FileVault on, SIP enabled}"

  $QUIET && return

  # Raw output verbatim (no spctl — matches original)
  print_info "$fv_status"
  print_info "$sip_status"
}

# ──────────────────────────────────────────────
# ALL_MODULES — ordered list for dispatch
# ──────────────────────────────────────────────
ALL_MODULES=(identity brew agents storage ssd battery thermal memory processes docker timemachine updates wifi security)

# ──────────────────────────────────────────────
# parse_args
# ──────────────────────────────────────────────
parse_args() {
  SELECTED_MODULES=()
  SKIP_MODULES=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --version)
        echo "ctscan $VERSION"
        exit 0
        ;;
      --help|-h)
        print_usage
        exit 0
        ;;
      --no-color)
        USE_COLOR=false
        shift
        ;;
      --quiet)
        QUIET=true
        shift
        ;;
      --skip)
        shift
        if [[ $# -eq 0 ]]; then
          print_error "--skip requires a comma-separated list of modules"
          exit 1
        fi
        IFS=',' read -ra SKIP_MODULES <<< "$1"
        for sk in "${SKIP_MODULES[@]}"; do
          local valid=false
          for m in "${ALL_MODULES[@]}"; do
            [[ "$m" == "$sk" ]] && valid=true && break
          done
          if ! $valid; then
            print_error "Invalid skip module: $sk"
            exit 1
          fi
        done
        shift
        ;;
      --format)
        shift
        if [[ $# -eq 0 ]]; then
          print_error "--format requires a value: json"
          exit 1
        fi
        if [[ "$1" != "json" ]]; then
          print_error "--format value must be 'json' (got: $1)"
          exit 1
        fi
        FORMAT="json"
        shift
        ;;
      --*)
        print_error "Unknown option: $1"
        print_usage >&2
        exit 1
        ;;
      *)
        # Positional = module name
        local valid=false
        for m in "${ALL_MODULES[@]}"; do
          [[ "$m" == "$1" ]] && valid=true && break
        done
        if ! $valid; then
          print_error "Unknown module: $1"
          exit 1
        fi
        SELECTED_MODULES+=("$1")
        shift
        ;;
    esac
  done
}

print_usage() {
  cat <<EOF
ctscan $VERSION — macOS system health scanner

USAGE:
  ctscan [OPTIONS] [MODULES...]

MODULES (default: all):
  identity    System identity & uptime
  brew        Brew hygiene
  agents      Launch agents & daemons
  storage     Storage analytics
  ssd         SSD wear level (requires smartmontools)
  battery     Battery analytics
  thermal     Thermal & GPU state
  memory      RAM pressure & swap
  processes   Top CPU & memory consumers
  docker      Running containers & disk usage
  timemachine Last backup date & status
  updates     Pending macOS software updates
  wifi        Network signal strength
  security    Security & SIP status

OPTIONS:
  --skip <mod1,mod2>   Skip specified modules
  --no-color           Disable colored output (for pipe/CI)
  --quiet              Print critical values only
  --format json        Emit structured JSON (suppresses all text output)
  --version            Print version
  --help               Print usage

EXAMPLES:
  ctscan                        # run all modules
  ctscan battery wifi           # run only these two
  ctscan --skip ssd storage     # run all except these
  ctscan --no-color | tee log.txt
EOF
}

# ──────────────────────────────────────────────
# run_modules
# ──────────────────────────────────────────────
run_modules() {
  _maybe_silence_printing
  local to_run=()

  if [[ ${#SELECTED_MODULES[@]} -gt 0 ]]; then
    # Use explicit selection (preserving ALL_MODULES order) — O(n) via case
    local sel_pat="|"
    for s in "${SELECTED_MODULES[@]}"; do sel_pat+="$s|"; done
    for m in "${ALL_MODULES[@]}"; do
      case "$sel_pat" in *"|$m|"*) to_run+=("$m");; esac
    done
  else
    to_run=("${ALL_MODULES[@]}")
  fi

  # Apply --skip — O(n) via case
  local skip_pat="|"
  for sk in "${SKIP_MODULES[@]}"; do skip_pat+="$sk|"; done
  local final=()
  for m in "${to_run[@]}"; do
    case "$skip_pat" in *"|${m}|"*) continue;; esac
    final+=("$m")
  done

  # F10: Parallelize system_profiler calls (identity, thermal, wifi)
  local _sp_dir; _sp_dir=$(mktemp -d "${TMPDIR:-/tmp}/ctscan.XXXXXXXX")
  local _need_hw=false _need_wifi=false _need_gpu=false
  for f in "${final[@]}"; do
    [[ "$f" == "identity" ]] && _need_hw=true
    [[ "$f" == "wifi" ]] && _need_wifi=true
    [[ "$f" == "thermal" ]] && _need_gpu=true
  done
  $_need_hw && system_profiler SPHardwareDataType > "$_sp_dir/hw" 2>/dev/null &
  $_need_wifi && system_profiler SPAirPortDataType > "$_sp_dir/airport" 2>/dev/null &
  $_need_gpu && system_profiler SPDisplaysDataType > "$_sp_dir/displays" 2>/dev/null &
  if $_need_hw || $_need_wifi || $_need_gpu; then wait; fi
  $_need_hw && _SP_HARDWARE=$(< "$_sp_dir/hw")
  $_need_wifi && _SP_AIRPORT=$(< "$_sp_dir/airport")
  $_need_gpu && _SP_DISPLAYS=$(< "$_sp_dir/displays")
  rm -rf "$_sp_dir"

  for mod in "${final[@]}"; do
    "check_${mod}"
    echo
  done

  if [[ "$FORMAT" == "json" ]]; then
    emit_json
  else
    color "0;90" "  ctscan $VERSION"
  fi
}

# ──────────────────────────────────────────────
# Main
# ──────────────────────────────────────────────
main() {
  parse_args "$@"
  run_modules
}

main "$@"
